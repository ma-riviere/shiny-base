{
    "name": "shiny-base-e2e",
    "private": true,
    "scripts": {
        "test": "npx playwright test",
        "test:headed": "npx playwright test --headed",
        "test:dev": "npx playwright test --project=dev",
        "test:dev:headed": "npx playwright test --project=dev --headed",
        "test:admin": "npx playwright test --project=admin",
        "test:admin:headed": "npx playwright test --project=admin --headed",
        "test:user": "npx playwright test --project=user",
        "test:user:headed": "npx playwright test --project=user --headed",
        "test:ui": "npx playwright test --ui",
        "test:workflow": "npx playwright test workflow-dataset-model.spec.js --project=dev",
        "test:debug": "npx playwright test --debug",
        "report": "npx playwright show-report",
        "setup": "npx playwright install chromium",
        "legacy": "node run-all.js"
    },
    "dependencies": {
        "@faker-js/faker": "^10.1.0",
        "@playwright/test": "^1.57.0",
        "playwright": "^1.40.0"
    }
}